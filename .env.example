# 必填：Anthropic API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-xxx

# 可选：模型名（默认 claude-sonnet-4-6）
AIPPT_MODEL=claude-sonnet-4-6

# 可选：服务监听地址
AIPPT_HOST=127.0.0.1
AIPPT_PORT=8000

# 可选：是否启用 Sonnet web search 工具（默认 true）
AIPPT_ENABLE_WEB_SEARCH=true

# 可选：单次生成的最大输出 token
AIPPT_MAX_TOKENS=8192

# 可选：Mock 模式 — 不调 Sonnet，返回示例 Deck。
# 适合没 API key 时演示流程、CI 跑端到端测试。
AIPPT_MOCK=false
